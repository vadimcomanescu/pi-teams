{
  "name": "@vadimcomanescu/pi-teams",
  "version": "1.0.2",
  "description": "Pi team orchestration extension for named teammates, shared task boards, and raw worker delegation",
  "author": "Vadim Comanescu",
  "contributors": ["Nico Bailon"],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vadimcomanescu/pi-teams.git"
  },
  "homepage": "https://github.com/vadimcomanescu/pi-teams#readme",
  "bugs": {
    "url": "https://github.com/vadimcomanescu/pi-teams/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "teams",
    "coordinator",
    "tasks",
    "teammates",
    "ai",
    "agents",
    "workers",
    "cli"
  ],
  "bin": {
    "pi-teams": "install.mjs"
  },
  "files": [
    "*.ts",
    "!*.test.ts",
    "*.js",
    "*.mjs",
    "agents/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test *.test.ts",
    "test:integration": "node --experimental-transform-types --import ./test/register-loader.mjs --test test/*.test.ts",
    "test:e2e": "node --experimental-transform-types --import ./test/register-loader.mjs --test test/e2e-*.test.ts",
    "test:all": "node --experimental-transform-types --import ./test/register-loader.mjs --test *.test.ts test/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts",
      "./notify.ts"
    ]
  },
  "devDependencies": {
    "@marcfargas/pi-test-harness": "^0.5.0",
    "@mariozechner/pi-agent-core": "^0.62.0",
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0"
  }
}
